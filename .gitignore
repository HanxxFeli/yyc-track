# ── Monorepo root .gitignore ──────────────────────────────────────────────────

# Environment files — never commit these
.env
.env.local
.env.*.local

# Each app has its own node_modules
**/node_modules/

# Build outputs
**/dist/
**/.next/
**/build/

# Azure Functions compiled output
apps/functions/dist/

# Local settings (Azure Functions equivalent of .env)
apps/functions/local.settings.json

# OS files
.DS_Store
Thumbs.db

# Editor
.vscode/settings.json
.idea/

# Docker
.dockerignore